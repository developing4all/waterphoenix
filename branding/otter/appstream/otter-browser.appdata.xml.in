<component>
  <id>@BRAND_APPLICATION_ID@</id>
  <launchable type="desktop-id">@BRAND_DESKTOP_FILE_NAME@</launchable>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>@BRAND_DISPLAY_FULL_NAME@</name>
  <summary>Web browser controlled by the user, not vice-versa</summary>
  <description>
    <p>
      @BRAND_DISPLAY_FULL_NAME@ aims to recreate the best aspects of the classic Opera (12.x) UI using Qt6.
    </p>
  </description>
  <kudos>
    <kudo>HiDpiIcon</kudo>
    <kudo>ModernToolkit</kudo>
  </kudos>
  <screenshots>
    <screenshot type="default">
      <image>@BRAND_WEBSITE_URL@/screenshots/1.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/8.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/9.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/5.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/16.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/17.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/18.png</image>
    </screenshot>
    <screenshot>
      <image>@BRAND_WEBSITE_URL@/screenshots/19.png</image>
    </screenshot>
  </screenshots>
  <url type="homepage">@BRAND_WEBSITE_URL@</url>
  <url type="bugtracker">@BRAND_WEBSITE_URL@/issues</url>
  <url type="faq">@BRAND_WEBSITE_URL@/#faq</url>
  <url type="translate">@BRAND_WEBSITE_URL@/translations</url>
  <categories>
    <category>Network</category>
    <category>WebBrowser</category>
  </categories>
  <update_contact>martinkg@fedoraproject.org</update_contact>
</component>
