#include <windows.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION @BRAND_VERSION_MAJOR@,@BRAND_VERSION_MINOR@,@BRAND_VERSION_PATCH@,0
PRODUCTVERSION @BRAND_VERSION_MAJOR@,@BRAND_VERSION_MINOR@,@BRAND_VERSION_PATCH@,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "@BRAND_ORGANIZATION_NAME@"
            VALUE "FileDescription", "@BRAND_DISPLAY_FULL_NAME@"
            VALUE "FileVersion", "@BRAND_VERSION_MAJOR@.@BRAND_VERSION_MINOR@.@BRAND_VERSION_PATCH@"
            VALUE "InternalName", "@BRAND_EXECUTABLE_NAME@"
            VALUE "LegalCopyright", "Copyright © @BRAND_COPYRIGHT_YEAR@ @BRAND_ORGANIZATION_NAME@"
            VALUE "OriginalFilename", "@BRAND_EXECUTABLE_NAME@.exe"
            VALUE "ProductName", "@BRAND_DISPLAY_FULL_NAME@"
            VALUE "ProductVersion", "@BRAND_VERSION_MAJOR@.@BRAND_VERSION_MINOR@.@BRAND_VERSION_PATCH@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

@BRAND_EXECUTABLE_NAME@_ICON ICON "@BRAND_ICON_NAME@.ico"

@BRAND_EXECUTABLE_NAME@_DOCUMENT_ICON ICON "@BRAND_ICON_NAME@-document.ico"
